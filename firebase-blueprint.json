{
  "entities": {
    "UserUsage": {
      "title": "User Usage",
      "description": "Tracks user generation usage and limits",
      "type": "object",
      "properties": {
        "generations": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "date-time"
          },
          "description": "List of timestamps of successful generations in the last 24 hours"
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "videoName": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "language": { "type": "string" },
              "mode": { "type": "string" }
            }
          },
          "description": "History of generated transcriptions"
        },
        "email": {
          "type": "string",
          "description": "User email for reference"
        }
      },
      "required": ["generations"]
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Aggregated statistics for the application",
      "type": "object",
      "properties": {
        "anonymousGenerations": {
          "type": "integer",
          "description": "Total generations made by anonymous users with their own API key"
        },
        "totalGoogleUsers": {
          "type": "integer",
          "description": "Total number of unique Google users (calculated or cached)"
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserUsage",
      "description": "User usage data"
    },
    "/stats/global": {
      "schema": "GlobalStats",
      "description": "Global application statistics"
    }
  }
}
